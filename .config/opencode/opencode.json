{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "default_agent": "plan",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{file:~/.config/opencode/.secrets/context7-key}"
      }
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest"
  ]
}
